    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [152, 16.0]
    rotation: 0
    state: enabled
- name: out_file
  id: variable
  parameters:
    comment: ''
    value: '"scripts/fm_demod_proto/fm_proto_data/capture_94p4_iq_c64.bin"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [456, 16.0]
    rotation: 0
    state: enabled
- name: record_seconds
  id: variable
  parameters:
    comment: ''
    value: '10'
  states:
